# --- OpenRouter (default LLM_PROVIDER=openrouter) ---
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openrouter/free

# --- Groq: Llama 3.3 70B (bukan xAI Grok) — set LLM_PROVIDER=groq ---
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# Bahasa narasi AI: id | en (menimpa player.language). Kosongkan agar pakai state + perintah LANG di game.
# NARRATION_LANG=id
# Batas token output (opsional); default Groq 4096, OpenRouter 2000
# LLM_MAX_TOKENS=4096

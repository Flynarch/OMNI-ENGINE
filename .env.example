# --- OpenRouter (default LLM_PROVIDER=openrouter) ---
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openrouter/free

# --- Groq: Llama 3.3 70B (bukan xAI Grok) — set LLM_PROVIDER=groq ---
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# NL "stay one night" / menginap → auto `stay_checkin` when parser matches (default off; needs enough cash).
# OMNI_AUTO_STAY_INTENT=1

# FFCI (free-form custom intent): LLM resolver + merge (default on). Shadow = log LLM intent but mechanics from parser only.
# OMNI_FFCI_ENABLED=1
# OMNI_FFCI_SHADOW_ONLY=0
# Max high/medium-stakes custom intents per in-game day (anti-spam).
# OMNI_FFCI_CUSTOM_HIGH_RISK_CAP_PER_DAY=4

# Spinner while waiting for LLM (intent + narration). Set 0 to disable.
# OMNI_LLM_HEARTBEAT=1

# Feed prune (world_notes + world.news_feed → save/archive.json). Applied on world_tick, load_state, save_state.
# Integers; engine clamps each to a safe range (see README).
# OMNI_FEED_MAX_AGE_DAYS=7
# OMNI_FEED_MAX_ENTRIES=100
# OMNI_FEED_ARCHIVE_LIST_CAP=5000

# Swallowed-exception file log (engine/core/error_taxonomy.py). Never blocks gameplay.
# Default: append to logs/engine_errors.log (UTF-8). Uncomment to disable file logging:
# OMNI_ENGINE_ERROR_LOG_DISABLE=1
# Custom log file path (optional; relative paths resolve from process cwd):
# OMNI_ENGINE_ERROR_LOG_PATH=logs/engine_errors.log

# Dev: invalid pack extras fail-fast (same effect as OMNI_STRICT_PACK_EXTRAS).
# STRICT_PACK_VALIDATION=1

# Roll / NPC tuning (optional; see engine/balance.py Balance dataclass):
# BAL_SKILL_MOD_PER_LEVEL=2
# BAL_SKILL_MOD_MAX_CAP=24
# BAL_LANG_BARRIER_SCALE_PCT=100
# BAL_DISGUISE_SOCIAL_ROLL_BONUS=4
# BAL_DISGUISE_STEALTH_ROLL_BONUS=6
# BAL_WEATHER_ROLL_MOD_SCALE_PCT=100
# BAL_NPC_PURSUIT_DAYS=2
# BAL_NPC_SURRENDER_MORALE=22
# BAL_NPC_BACKUP_TRACE_DELTA=4

# Bio / vitals (engine/bio.py): blood thresholds, infection bands, sleep/hallucination, hygiene tax, rest debt clear rate
# BAL_BIO_BP_STABLE_MIN=4.25
# BAL_BIO_BP_LOW_MIN=3.5
# BAL_BIO_BP_CRITICAL_MIN=3.0
# BAL_BIO_INFECTION_MID_LOW=20
# BAL_BIO_INFECTION_MID_HIGH=50
# BAL_BIO_INFECTION_RECOVERY_PENALTY=10
# BAL_BIO_SLEEP_DEBT_VISUAL=42
# BAL_BIO_SLEEP_DEBT_AUDIO=30
# BAL_BIO_SANITY_VISUAL=80
# BAL_BIO_SANITY_AUDIO=60
# BAL_BIO_SANITY_PSYCHOTIC=90
# BAL_BIO_HYGIENE_HOURS_TAX=48
# BAL_BIO_REST_DEBT_CLEAR_PER_90MIN=4

# Bahasa narasi AI: id | en (menimpa player.language). Kosongkan agar pakai state + perintah LANG di game.
# NARRATION_LANG=id
# Batas token output (opsional); default Groq 4096, OpenRouter 2000
# LLM_MAX_TOKENS=4096
# Retry HTTP untuk narasi (streaming) dan intent resolver (JSON) — jaringan / 429 / 5xx (default 4)
# LLM_HTTP_RETRIES=4
# Local fallback (Ollama) saat external timeout/503 setelah beberapa retry.
# LLM_LOCAL_FALLBACK_ENABLED=1
# LLM_LOCAL_FALLBACK_AFTER_RETRIES=2
# LLM_LOCAL_BASE_URL=http://localhost:11434/api/generate
# LLM_LOCAL_MODEL=llama3.2:3b

# ------------------------------
# Optional: Balance overrides (advanced)
# These values are SNAPSHOTTED into save files (meta.balance) at boot/load.
# If you change them later, existing saves will keep the old snapshot unless you delete the save.
#
# Examples:
# BAL_DISGUISE_COST_CASH=25
# BAL_SAFEHOUSE_RENT_PER_DAY=15
# BAL_WEATHER_TRAVEL_STORM_MIN=35
#
# Full list (all integers):
# BAL_DISGUISE_DEFAULT_DURATION_MIN
# BAL_DISGUISE_COST_CASH
# BAL_DISGUISE_TRACE_RELIEF
# BAL_DISGUISE_PUBLIC_RISK_ADD
# BAL_DISGUISE_RISK_CAP
# BAL_DISGUISE_CAUGHT_TRACE_SPIKE
# BAL_SAFEHOUSE_RENT_DEPOSIT
# BAL_SAFEHOUSE_RENT_PER_DAY
# BAL_SAFEHOUSE_BUY_PRICE
# BAL_SAFEHOUSE_UPGRADE_BASE_COST
# BAL_SAFEHOUSE_SECURITY_MAX
# BAL_SAFEHOUSE_LAY_LOW_BASE_DECAY
# BAL_SAFEHOUSE_DELINQUENT_REPORT_DAY
# BAL_SAFEHOUSE_LANDLORD_REPORT_TRACE_DELTA
# BAL_TRAVEL_FRICTION_POLICE_SWEEP_MIN
# BAL_TRAVEL_FRICTION_LOCKDOWN_MIN
# BAL_WEATHER_TRAVEL_STORM_MIN
# BAL_WEATHER_TRAVEL_RAIN_MIN
# BAL_WEATHER_TRAVEL_FOG_MIN
# BAL_WEATHER_TRAVEL_WINDY_MIN
# BAL_WEATHER_STEALTH_BONUS_RAIN_FOG
# BAL_WEATHER_STEALTH_BONUS_STORM
